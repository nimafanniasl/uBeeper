#!/bin/bash

export GDK_BACKEND=wayland
export PATH=$PWD/bin:$PATH

# This is ridiculous
wsf=$HOME/.cache/lomiri/windowstatestorage.sqlite
if [ -f "$wsf" ]; then
    sqlite3 "$wsf" "delete from state where windowId like 'com.smartnima.ubeeper';"
fi

exec ./beeper --no-sandbox --ozone-platform=wayland "$@"
